# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...            # 2500 HUF product price ID
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare Stream ─────────────────────────────────────────
CF_ACCOUNT_ID=...
CF_STREAM_ID=...                     # Live Input or Video ID
CF_STREAM_KEY_ID=...                 # Signing key ID from CF dashboard
CF_STREAM_PRIVATE_KEY=...            # RSA private key for JWT signing (PEM, base64)

# ─── Database (pick one) ───────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/cagewars

# ─── Supabase (if using Supabase Auth) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...
